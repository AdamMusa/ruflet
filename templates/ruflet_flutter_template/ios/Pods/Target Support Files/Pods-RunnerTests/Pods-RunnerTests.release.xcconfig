OTHER_LDFLAGS = $(inherited) -ObjC -l"sqlite3" -l"z" -framework "AVFoundation" -framework "AVKit" -framework "Ass" -framework "AudioToolbox" -framework "Avcodec" -framework "Avfilter" -framework "Avformat" -framework "Avutil" -framework "CFNetwork" -framework "CoreGraphics" -framework "CoreMedia" -framework "CoreTelephony" -framework "CoreVideo" -framework "Dav1d" -framework "Foundation" -framework "Freetype" -framework "Fribidi" -framework "Harfbuzz" -framework "ImageIO" -framework "JavaScriptCore" -framework "Mbedcrypto" -framework "Mbedtls" -framework "Mbedx509" -framework "MediaPlayer" -framework "MessageUI" -framework "MobileCoreServices" -framework "Mpv" -framework "Network" -framework "Photos" -framework "Png16" -framework "QuartzCore" -framework "Security" -framework "StoreKit" -framework "Swresample" -framework "Swscale" -framework "SystemConfiguration" -framework "UIKit" -framework "Uchardet" -framework "WebKit" -framework "Xml2"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
